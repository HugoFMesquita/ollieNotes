#!/usr/bin/env bash
# note-preview — open current note as a rendered Markdown preview in the browser
# Uses grip to render GitHub-flavored Markdown.
# Usage: note-preview <filepath>

FILEPATH="$1"

if [[ -z "${FILEPATH}" || ! -f "${FILEPATH}" ]]; then
  notify-send --app-name="Notes" "Preview failed" "No file to preview." 2>/dev/null
  exit 1
fi

if ! command -v grip &>/dev/null; then
  notify-send --app-name="Notes" "Preview failed" "grip is not installed. Run: pipx install grip" 2>/dev/null
  exit 1
fi

# Pick a random free port so multiple previews don't collide
PORT=$(shuf -i 6400-6500 -n 1)

# Start grip as a background server, then open the browser
grip "${FILEPATH}" "${PORT}" --quiet &
GRIP_PID=$!

# Wait briefly for grip to start listening, then open browser
sleep 1
xdg-open "http://localhost:${PORT}" 2>/dev/null

# Keep grip alive until it's manually killed or the port is freed
wait "${GRIP_PID}"
