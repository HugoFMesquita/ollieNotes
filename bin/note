#!/usr/bin/env bash
# note — create a new note, name derived from H1 heading on save

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
NOTES_DIR="${HOME}/Notes"
MICRO_CONFIG_HOME="${SCRIPT_DIR}/../config/micro"

mkdir -p "${NOTES_DIR}"

# Create a temp file with frontmatter scaffold
TMPFILE="$(mktemp "${NOTES_DIR}/.new-note-XXXXXX.md")"

cat > "${TMPFILE}" <<'EOF'
---
tags: []
created: CREATED_DATE
updated: UPDATED_DATE
---

# 
EOF

NOW="$(LC_TIME=C date +'%Y-%m-%d %a %H:%M')"
sed -i "s/CREATED_DATE/${NOW}/; s/UPDATED_DATE/${NOW}/" "${TMPFILE}"

# Open in micro — +7:3 places cursor after "# " on the H1 line
MICRO_CONFIG_HOME="${MICRO_CONFIG_HOME}" \
  micro -ruler false -wordwrap true +7:3 "${TMPFILE}"

# --- Post-close: parse #hashtags from body into frontmatter ---
"${SCRIPT_DIR}/note-parse-tags" "${TMPFILE}"

# --- Post-save: derive filename from H1 ---
H1="$(grep -m1 '^# ' "${TMPFILE}" | sed 's/^# //' | xargs)"

if [[ -z "${H1}" ]]; then
  # No title: use timestamp
  FINAL_NAME="$(date +'%Y%m%d-%H%M%S').md"
else
  # Slugify: lowercase, replace spaces/special chars with hyphens
  SLUG="$(echo "${H1}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/-\+/-/g' | sed 's/^-\|-$//g')"
  # Guard: H1 was non-blank but contained only non-alphanumeric chars (e.g. "!!!")
  # which all got stripped, leaving an empty slug → fall back to timestamp to
  # avoid producing a dotfile (".md") as the note name.
  if [[ -z "${SLUG}" ]]; then
    SLUG="$(date +'%Y%m%d-%H%M%S')"
  fi
  FINAL_NAME="${SLUG}.md"
fi

# Update title in frontmatter and updated date
UPDATED_NOW="$(LC_TIME=C date +'%Y-%m-%d %a %H:%M')"
sed -i "s/^updated:.*/updated: ${UPDATED_NOW}/" "${TMPFILE}"

# Handle duplicate filenames
FINAL_PATH="${NOTES_DIR}/${FINAL_NAME}"
if [[ -e "${FINAL_PATH}" ]]; then
  BASE="${FINAL_NAME%.md}"
  FINAL_PATH="${NOTES_DIR}/${BASE}-$(date +'%H%M%S').md"
fi

# Only save if file has content beyond the scaffold (ignore bare "# " with no title)
CONTENT="$(grep -v '^---' "${TMPFILE}" | grep -v '^tags:' | grep -v '^created:' | grep -v '^updated:' | grep -v '^# \?$' | tr -d '[:space:]')"
if [[ -z "${CONTENT}" ]]; then
  rm -f "${TMPFILE}"
else
  mv "${TMPFILE}" "${FINAL_PATH}"
  (setsid "${SCRIPT_DIR}/note-sync" "${FINAL_PATH}" </dev/null &)
fi
