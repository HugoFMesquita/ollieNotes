#!/usr/bin/env bash
# note-open — fuzzy browse notes, preselecting the last edited one

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
NOTES_DIR="${HOME}/Notes"
MICRO_CONFIG_HOME="${SCRIPT_DIR}/../config/micro"

mkdir -p "${NOTES_DIR}"

NOTES="$("${SCRIPT_DIR}/note-list")"

if [[ -z "${NOTES}" ]]; then
  echo "No notes found in ${NOTES_DIR}"
  sleep 2
  exit 0
fi

# fzf display: output from note-list is already formatted; filepath is field 2 (tab-delimited)
SELECTED="$(echo "${NOTES}" \
  | fzf \
      --ansi \
      --layout=reverse \
      --border=rounded \
      --border-label=" 󰎚 Notes " \
      --prompt="  " \
      --pointer="▶" \
      --query="" \
      --no-multi \
      --with-nth=1 \
      --delimiter='\t' \
      --preview='bat --style=plain --color=always --language=md {2}' \
      --preview-window='right:55%:wrap' \
      --bind "ctrl-d:execute(${SCRIPT_DIR}/note-delete {2})+reload(${SCRIPT_DIR}/note-list)" \
      --header="  enter:open  ctrl-d:delete  esc:quit" \
)"

# Extract filepath (second tab-field, after the formatted display)
FILEPATH="$(echo "${SELECTED}" | awk -F'\t' '{print $2}' | xargs)"

[[ -z "${FILEPATH}" ]] && exit 0

# Update the 'updated' frontmatter field on open
TODAY="$(LC_TIME=C date +'%Y-%m-%d %a %H:%M')"
sed -i "s/^updated:.*/updated: ${TODAY}/" "${FILEPATH}"

MICRO_CONFIG_HOME="${MICRO_CONFIG_HOME}" \
  micro -ruler false -softwrap true -wordwrap true "${FILEPATH}"

# Parse #hashtags from body into frontmatter tags:
"${SCRIPT_DIR}/note-parse-tags" "${FILEPATH}"

# Sync to GitHub — run synchronously so it completes before RunInteractiveShell
# returns control to micro. note-sync redirects all output to ~/.notes-sync.log
# immediately, so this does not produce any visible terminal output.
"${SCRIPT_DIR}/note-sync" "${FILEPATH}"
